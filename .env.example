# Environment Variables Template
# Salin file ini ke .env dan isi sesuai environment

# ===== Database (PostgreSQL) =====
DATABASE_URL=postgresql://user:password@localhost:5432/ths_thm_db
# Production: DATABASE_URL=postgresql://user:password@host:5432/ths_thm_db?sslmode=require

# ===== JWT Authentication =====
JWT_SECRET=change-me-to-random-64-char-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-random-64-char-string
JWT_REFRESH_EXPIRES_IN=7d

# ===== App Config =====
APP_PORT=3001
NODE_ENV=development
# Production: NODE_ENV=production

# ===== CORS =====
FRONTEND_URL=http://localhost:3000
MOBILE_URL=http://localhost:8081
# Production: FRONTEND_URL=https://ths-thm.example.com

# ===== Upload Config =====
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
# 10 MB max upload

# ===== Email (Resend — primary) =====
# Daftar di https://resend.com → API Keys → Create API Key
# Add domain: https://resend.com/domains → verifikasi DNS (TXT record)
RESEND_API_KEY=re_xxx
RESEND_DOMAIN=mail.example.com

# ===== Email (SMTP — fallback, optional) =====
# Hanya dipakai jika Resend tidak tersedia
# Install package: cd apps/api && pnpm add nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ===== Firebase Cloud Messaging =====
FCM_PROJECT_ID=your-fcm-project-id
FCM_PRIVATE_KEY=your-fcm-private-key
FCM_CLIENT_EMAIL=your-client-email@your-project.iam.gserviceaccount.com
FCM_DATABASE_URL=https://your-project.firebaseio.com

# ===== Stripe Payments =====
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ===== Render Deployment =====
# RENDER=true
# RENDER_SERVICE_ID=srv-xxxxx
# PORT will be set automatically by Render