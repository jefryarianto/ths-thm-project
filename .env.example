# ─── Database ───
DATABASE_URL="postgresql://ths_thm:ths_thm_secret@localhost:5432/ths_thm_db?schema=public"

# ─── Valkey / Redis ───
REDIS_URL="redis://localhost:6379"

# ─── JWT ───
JWT_SECRET="change-this-to-a-strong-random-secret"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ─── MinIO / S3 ───
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="ths-thm-docs"
MINIO_USE_SSL=false
S3_REGION="auto"

# ─── Firebase Admin SDK ───
# Option 1: Service account JSON string (preferred)
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}'
# Option 2: Path to service account JSON file
# FIREBASE_SERVICE_ACCOUNT_PATH="/path/to/firebase-service-account.json"
# Option 3: Application Default Credentials (GCP environment)
# FIREBASE_PROJECT_ID="your-firebase-project-id"
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/credentials.json"

# ─── App ───
API_PORT=4000
API_URL="http://localhost:4000"
# Trust proxy — set to 1 if behind Nginx/Cloudflare/etc., 0 for direct access
TRUST_PROXY=1
WEB_ADMIN_PORT=3000
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ─── Document Generation ───
DOCUMENTS_STORAGE="minio" # minio | local
UPLOAD_DIR="./uploads"
